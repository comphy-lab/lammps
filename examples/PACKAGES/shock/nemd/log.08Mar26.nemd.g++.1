# nemd simulation

reset_timestep	0

# estimate location of shock front assuming ideal kinematics
# i.e. P(t) = P0 * (L0+u0*t-xs)/L0, requires u1 = 0
compute	   	mymom all momentum
variable	xshock equal (1.0+c_mymom[1]/(atoms*${mass})/${up})*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/${up})*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/22.4)*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/22.4)*lx-22.4*time
fix             xshockprev all vector ${nthermo} v_xshock nmax 2
fix             xshockprev all vector 100 v_xshock nmax 2
variable        ushock equal (f_xshockprev[2]-f_xshockprev[1])/(${nthermo}*${dt})+${up}
variable        ushock equal (f_xshockprev[2]-f_xshockprev[1])/(100*${dt})+${up}
variable        ushock equal (f_xshockprev[2]-f_xshockprev[1])/(100*0.0005)+${up}
variable        ushock equal (f_xshockprev[2]-f_xshockprev[1])/(100*0.0005)+22.4
run             ${nthermo} # needed to fil both entries in xshockprev vector
run             100 
