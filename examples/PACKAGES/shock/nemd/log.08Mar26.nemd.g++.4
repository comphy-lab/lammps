# nemd simulation

reset_timestep	0

# estimate location of shock front assuming ideal kinematics
compute	   	mymom all momentum
variable	xshock equal (1.0+c_mymom[1]/(atoms*${mass})/${up})*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/${up})*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/22.4)*lx-${up}*time
variable	xshock equal (1.0+c_mymom[1]/(atoms*1.0)/22.4)*lx-22.4*time

thermo		${nthermo}
thermo		100
thermo_style  	custom step spcpu temp pe density etotal press v_xshock lx

# add impact velocity in minus x

variable	upneg equal -${up}
variable	upneg equal -22.4
velocity	all set ${upneg} 0.0 0.0 sum yes units box
velocity	all set -22.4 0.0 0.0 sum yes units box

unfix		mynvt
fix		mynve all nve

# create group for bulk atoms, to avoid surface artefacts

variable        bulklo equal xlo+${leftbulkpad}
variable        bulklo equal xlo+5.0
variable        bulkhi equal xhi-${rightbulkpad}
variable        bulkhi equal xhi-30.0
region		bulk block ${bulklo} ${bulkhi} INF INF INF INF units box
region		bulk block 5 ${bulkhi} INF INF INF INF units box
region		bulk block 5 23.4539230884204 INF INF INF INF units box
group           bulk region bulk
1036 atoms in group bulk


# fix set command to check for threshold crossings every step
# when crossing occurs set d_xshock first, then set i_tshock

variable        vxthresh equal ${upneg}*0.5 # threshold velocity = (u0+u1)/2
variable        vxthresh equal -22.4*0.5 
fix             vxave all ave/atom 1 ${nevery} ${nevery} vx
fix             vxave all ave/atom 1 1 ${nevery} vx
fix             vxave all ave/atom 1 1 1 vx
variable        istart atom "f_vxave > v_vxthresh && i_tshock == -1"
variable        tshock equal step-${nevery}
variable        tshock equal step-1
variable        inew atom ternary(v_istart,v_tshock,i_tshock)
variable        dnew atom ternary(v_istart,x,d_xshock)
fix             setshock all set ${nevery} 0 group all d_xshock v_dnew i_tshock v_inew
fix             setshock all set 1 0 group all d_xshock v_dnew i_tshock v_inew

# set up vx history, c_vxhist[*][1] not yet supported

