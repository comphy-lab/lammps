#------------Thermosettings------------
timestep        1.0
thermo          10
thermo_style    custom step temp press density ke pe etotal evdwl ecoul epair ebond eangle edihed eimp
# restart         10 rst1.a.${myid} rst2.a.${myid}


#------------Run some dynamics------------
velocity        all create 300 ${pseed} rot yes mom yes
velocity        all create 300 12345 rot yes mom yes
fix             1 all nvt temp 300 300 $(100*dt)
fix             1 all nvt temp 300 300 100

run             100

