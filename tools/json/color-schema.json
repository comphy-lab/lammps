{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://download.lammps.org/json/color-schema.json",
    "title": "JSON schema for LAMMPS default color and light definition for dump image",
    "description": "Version 0.1; last updated 2026-04-25",
    "type": "object",
    "properties": {
        "application": {
            "type": "string",
            "const": "LAMMPS"
        },
        "format": {
            "type": "string",
            "const": "colors"
        },
        "revision": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1
        },
        "schema": {"type": "string"},
        "title": {"type": "string"},
        "colors": {"type": "array",
                   "items": {
                       "properties" : {
                           "name" : { "type": "string"},
                           "red" : { "type": "number"},
                           "green" : { "type": "number"},
                           "blue" : { "type": "number"}
                       },
                       "required": ["red", "green", "blue"]
                   },
                   "minItems": 1
                  },
        "lights": {
            "type": "object",
            "properties": {
                "ambient": {"type": "number"},
                "key": {"type": "number"},
                "fill": {"type": "number"},
                "back": {"type": "number"}
            },
            "required": ["ambient", "key", "fill", "back"]
        }
    },
    "required": ["application", "format", "revision", "colors", "lights"]
}
